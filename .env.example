# ==============================================================
#  Digital Cultural Tourism Guide — Backend Environment Config
#  Copy this file to `.env` and replace the placeholders with
#  your own values:   cp .env.example .env
# ==============================================================

# --------------------------------------------------------------
#  Database — Prisma CLI (migrations / studio / generate)
# --------------------------------------------------------------
# Consumed by the Prisma CLI through prisma.config.ts.
# Used by:  prisma migrate deploy | prisma migrate dev | prisma studio
# MUST point to the SAME database as the DATABASE_* variables below.
DATABASE_URL="mysql://root:your_password@localhost:3306/tourism_db"

# --------------------------------------------------------------
#  Database — Runtime connection (MariaDB adapter)
# --------------------------------------------------------------
# Read directly at runtime by src/config/database.js
# (@prisma/adapter-mariadb). Keep them in sync with DATABASE_URL.
DATABASE_HOST="localhost"
DATABASE_USER="root"
DATABASE_PASSWORD="your_password"
DATABASE_NAME="tourism_db"
DATABASE_PORT=3306

# Required for MySQL 8+ (caching_sha2_password) over a non-TLS
# connection. Keep the EXACT lowercase spelling — this is the
# name the code actually reads (src/config/database.js).
allow_Public_Key_Retrieval=true

# --------------------------------------------------------------
#  JWT Authentication
# --------------------------------------------------------------
# Use a long, random string in production (e.g. `openssl rand -hex 32`).
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# --------------------------------------------------------------
#  Server
# --------------------------------------------------------------
PORT=3000
NODE_ENV="development"

# --------------------------------------------------------------
#  CORS
# --------------------------------------------------------------
# NOTE: the app currently allows all origins ("*") in src/app.js.
# This value is kept for when you want to lock CORS down later.
CORS_ORIGIN="http://localhost:3000"
